# Huawei Cloud Credentials
HUAWEI_AK=your_access_key_here
HUAWEI_SK=your_secret_key_here
HUAWEI_PROJECT_ID=your_project_id_here
HUAWEI_REGION=me-east-1

# Munsit — Arabic-dialect ASR + TTS (https://app.munsit.com/en/api-keys)
MUNSIT_API_KEY=your_munsit_api_key_here
MUNSIT_STT_MODEL=munsit
MUNSIT_TTS_MODEL=faseeh-mini-v1-preview
# Optional: pin a specific voice. If unset, backend auto-picks an Emirati/MSA voice.
MUNSIT_TTS_VOICE_ID=

# Flask
FLASK_DEBUG=true
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:8080,http://localhost:5173
