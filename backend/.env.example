# =====================================================
# Huawei Cloud Credentials — REQUIRED
# Get these from: Huawei Cloud Console → My Credentials
# =====================================================
HUAWEI_AK=your_access_key_here
HUAWEI_SK=your_secret_key_here

# SIS (Speech Interaction Service) — me-east-1 (ME-Riyadh)
# Used for: Real-Time TTS (Arabic/English), Short Audio ASR
HUAWEI_SIS_REGION=me-east-1
HUAWEI_SIS_PROJECT_ID=your_sis_project_id

# NLP Machine Translation — cn-north-4 (CN-North-Beijing4)
HUAWEI_NLP_REGION=cn-north-4
HUAWEI_NLP_PROJECT_ID=your_nlp_project_id

# Legacy single-region fallback (kept for backward compatibility)
HUAWEI_REGION=me-east-1
HUAWEI_PROJECT_ID=your_sis_project_id

# =====================================================
# Flask configuration
# =====================================================
FLASK_DEBUG=true
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# CORS origins (comma-separated, no trailing slash)
# - Local dev:   http://localhost:8080,http://localhost:5173
# - Production:  https://yourdomain.com
CORS_ORIGINS=http://localhost:8080,http://localhost:5173
